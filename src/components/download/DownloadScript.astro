<script>
  const bookingUrl = '/contact'

  // Keep legacy booking entry point available for direct links.
  const legacyBookingLinks = document.querySelectorAll('[data-legacy-booking-link]')
  for (const link of legacyBookingLinks) {
    if (link instanceof HTMLAnchorElement) {
      link.setAttribute('href', bookingUrl)
    }
  }
</script>
