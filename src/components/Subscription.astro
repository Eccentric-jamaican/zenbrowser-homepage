---
import { getLocale, getPath } from '~/utils/i18n'

const locale = getLocale(Astro)
const getLocalePath = getPath(locale)

const subscriptionTiers = [
  {
    id: 'essential',
    name: 'Essential Wellness',
    price: '$24,000',
    cadence: 'per month',
    detail: '4 sessions monthly',
    sessionRate: '$6,000/session when all used',
    services: 'Facial, Body Scrub, Swedish, Chair, Aromatherapy',
    bestFor: 'Weekly maintenance, lighter recovery, and stress support.',
    features: [
      'One fixed weekly appointment',
      'Choose from five core services',
      'Pause or adjust before the next billing cycle',
      'Best value for clients who already book weekly',
    ],
  },
  {
    id: 'premium',
    name: 'Premium Wellness',
    price: '$38,000',
    cadence: 'per month',
    detail: '4 sessions monthly',
    sessionRate: '$9,500/session when all used',
    services: 'All services, including Deep Tissue, Stone, Thai, and Hydro Therapy',
    bestFor: 'Deeper bodywork, mobility support, and full treatment flexibility.',
    features: [
      'One fixed weekly appointment',
      'Access to every treatment on the menu',
      'Priority booking for limited recovery slots',
      'Best value for deep tissue, stone, Thai, or hydro work',
    ],
  },
]

const tiersJson = JSON.stringify(subscriptionTiers)
---

<section
  id="subscription"
  data-motion-section
  class="relative flex w-full flex-col gap-10 py-12 text-start sm:py-16 lg:py-28"
>
  <div class="grid gap-8">
    <div class="max-w-4xl">
      <p class="mb-3 text-xs uppercase tracking-[0.3em] text-coral">Monthly care</p>
      <h2 class="max-w-2xl text-balance font-serif text-4xl font-medium leading-[1.04] sm:text-6xl">
        Orrrrrrrrrrrrrrrrr try the subscription.
      </h2>
      <p class="text-dark/70 mt-4 max-w-md">
        Reserve a weekly rhythm, keep the bodywork consistent, and choose the plan that fits how
        much support your month needs.
      </p>
    </div>

    <div
      class="subscription-shell border-dark/10 bg-paper/70 grid gap-5 rounded-lg border p-4 sm:p-6 lg:grid-cols-[0.95fr_1.05fr] lg:p-8"
    >
      <div class="flex flex-col justify-between gap-8">
        <div>
          <div
            class="subscription-toggle border-dark/10 relative grid max-w-md grid-cols-2 rounded-xl border bg-linen p-1"
            role="tablist"
            aria-label="Subscription tier"
          >
            <span class="subscription-toggle__indicator" aria-hidden="true"></span>
            {
              subscriptionTiers.map((tier, index) => (
                <button
                  type="button"
                  class:list={[
                    'subscription-toggle__button relative z-10 rounded-lg px-4 py-3 text-sm font-semibold transition-colors duration-300',
                    index === 0 ? 'is-active' : '',
                  ]}
                  data-tier-index={index}
                  role="tab"
                  aria-selected={index === 0 ? 'true' : 'false'}
                >
                  {tier.name.replace(' Wellness', '')}
                </button>
              ))
            }
          </div>

          <div class="mt-8">
            <p class="text-xs uppercase tracking-[0.25em] text-coral" data-subscription-detail>
              {subscriptionTiers[0].detail}
            </p>
            <h3 class="mt-3 font-serif text-4xl font-medium" data-subscription-name>
              {subscriptionTiers[0].name}
            </h3>
            <p class="text-dark/70 mt-4 max-w-md text-sm leading-relaxed" data-subscription-best>
              {subscriptionTiers[0].bestFor}
            </p>
          </div>
        </div>

        <div>
          <p class="font-serif text-6xl leading-none sm:text-7xl" data-subscription-price>
            {subscriptionTiers[0].price}
          </p>
          <p class="text-dark/55 mt-2 text-sm" data-subscription-cadence>
            {subscriptionTiers[0].cadence}
          </p>
        </div>
      </div>

      <article class="subscription-card rounded-lg bg-olive p-6 text-paper sm:p-8" data-motion-item>
        <div class="grid gap-8">
          <div>
            <p class="text-xs uppercase tracking-[0.22em] text-mint">What you get</p>
            <ul
              class="text-paper/85 mt-4 grid gap-3 text-sm leading-relaxed"
              data-subscription-features
            >
              {subscriptionTiers[0].features.map(feature => <li>{feature}</li>)}
            </ul>
          </div>

          <div
            class="border-paper/15 grid gap-4 border-t pt-6 sm:grid-cols-[1fr_auto] sm:items-center"
          >
            <p class="text-paper/65 text-xs leading-relaxed">
              Use it or lose it. 24h notice to reschedule. House calls are booked separately.
            </p>
            <a
              href={getLocalePath('/contact')}
              class="subscription-link inline-flex w-fit items-center justify-center rounded-xl border border-white/30 bg-paper px-5 py-3 text-sm font-semibold text-dark transition-transform duration-150 hover:scale-[1.02] active:scale-[0.98]"
            >
              Ask about this plan
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<script define:vars={{ tiersJson }}>
  const tiers = JSON.parse(tiersJson)
  const section = document.querySelector('#subscription')

  if (section) {
    const buttons = Array.from(section.querySelectorAll('[data-tier-index]'))
    const indicator = section.querySelector('.subscription-toggle__indicator')
    const fields = {
      detail: section.querySelector('[data-subscription-detail]'),
      name: section.querySelector('[data-subscription-name]'),
      bestFor: section.querySelector('[data-subscription-best]'),
      price: section.querySelector('[data-subscription-price]'),
      cadence: section.querySelector('[data-subscription-cadence]'),
      features: section.querySelector('[data-subscription-features]'),
    }

    const setTier = index => {
      const tier = tiers[index]
      if (!tier) return

      section.dataset.activeTier = tier.id
      indicator?.style.setProperty('--subscription-toggle-x', `${index * 100}%`)

      buttons.forEach((button, buttonIndex) => {
        const isActive = buttonIndex === index
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-selected', String(isActive))
      })

      section.classList.add('is-switching')
      window.setTimeout(() => section.classList.remove('is-switching'), 220)

      fields.detail.textContent = tier.detail
      fields.name.textContent = tier.name
      fields.bestFor.textContent = tier.bestFor
      fields.price.textContent = tier.price
      fields.cadence.textContent = tier.cadence
      fields.features.replaceChildren(
        ...tier.features.map(feature => {
          const item = document.createElement('li')
          item.textContent = feature
          return item
        })
      )
    }

    buttons.forEach(button => {
      button.addEventListener('click', () => setTier(Number(button.dataset.tierIndex)))
    })
  }
</script>

<style>
  .subscription-shell {
    background-image:
      linear-gradient(145deg, rgb(255 255 255 / 0.42), transparent 46%),
      linear-gradient(180deg, rgb(255 255 255 / 0.22), rgb(38 53 36 / 0.04));
  }

  .subscription-toggle__indicator {
    position: absolute;
    inset-block: 0.25rem;
    left: 0.25rem;
    width: calc(50% - 0.25rem);
    border-radius: 0.5rem;
    background: var(--zen-paper);
    transform: translateX(var(--subscription-toggle-x, 0));
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 1px 2px color-mix(in srgb, var(--zen-dark) 10%, transparent);
  }

  .subscription-toggle__button {
    color: color-mix(in srgb, var(--zen-dark) 58%, transparent);
  }

  .subscription-toggle__button.is-active {
    color: var(--zen-dark);
  }

  .subscription-card {
    transition:
      transform 260ms ease,
      opacity 260ms ease;
  }

  #subscription.is-switching .subscription-card {
    opacity: 0.82;
    transform: translateY(2px);
  }

  [data-subscription-features] li {
    display: flex;
    gap: 0.625rem;
    align-items: flex-start;
  }

  [data-subscription-features] li::before {
    content: '';
    flex: 0 0 auto;
    width: 0.45rem;
    height: 0.45rem;
    margin-top: 0.5rem;
    border-radius: 999px;
    background: var(--zen-mint, #63ddbb);
  }

  .subscription-link {
    overflow: hidden;
    background-image:
      linear-gradient(145deg, rgb(255 255 255 / 0.14), transparent 42%),
      linear-gradient(180deg, rgb(255 255 255 / 0.08), rgb(0 0 0 / 0.08));
  }
</style>
