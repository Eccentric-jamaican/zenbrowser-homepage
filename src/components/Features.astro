---
import { getLocale, getUI } from '~/utils/i18n'
import Description from './Description.astro'

const locale = getLocale(Astro)

const {
  routes: {
    index: { features },
  },
} = getUI(locale)

interface Props {
  titles?: string[]
}

const { titles } = Astro.props

const audienceTags: Record<string, string> = {
  facial: 'Skin refresh and calm',
  bodyScrub: 'Exfoliation and renewal',
  aromatherapy: 'Scent-led nervous system support',
  deepTissue: 'Pain that keeps returning',
  swedish: 'Stress and guarded muscles',
  stoneMassage: 'Heat, pressure, and deep ease',
  thai: 'Stiff joints and reduced mobility',
  triggerPoint: 'Headaches, sciatica, referral pain',
  hydroTherapy: 'Water-based recovery support',
}

const treatmentSprites: Record<string, string> = {
  facial: '/treatments/treatment-facial.png',
  bodyScrub: '/treatments/treatment-breath.png',
  aromatherapy: '/treatments/treatment-breath.png',
  deepTissue: '/treatments/treatment-deep-tissue.png',
  swedish: '/treatments/treatment-swedish.png',
  stoneMassage: '/treatments/treatment-hands.png',
  thai: '/treatments/treatment-thai.png',
  triggerPoint: '/treatments/treatment-trigger-point.png',
  hydroTherapy: '/treatments/treatment-mobility.png',
}
---

<section
  id="services"
  data-motion-section
  class="relative flex w-full flex-col overflow-hidden py-12 text-start sm:py-16 lg:py-32"
>
  <img
    src="/treatments/treatment-breath.png"
    alt=""
    aria-hidden="true"
    class="treatment-sprite treatment-sprite--breath pointer-events-none absolute right-0 top-14 hidden w-44 opacity-[0.08] lg:block"
    loading="lazy"
    decoding="async"
  />
  <img
    src="/treatments/treatment-mobility.png"
    alt=""
    aria-hidden="true"
    class="treatment-sprite treatment-sprite--spine pointer-events-none absolute bottom-16 left-4 hidden w-28 opacity-[0.1] lg:block"
    loading="lazy"
    decoding="async"
  />

  <p class="title-line mb-3 text-xs uppercase tracking-[0.3em] text-coral">Treatments</p>
  <Description class="mb-4 max-w-3xl font-serif text-4xl font-medium leading-[1.05] sm:text-6xl">
    {
      (titles || features.titles).map((title, index) =>
        title !== '\n' ? (
          <span class="title-line" data-index={index}>
            {title}
          </span>
        ) : (
          <br class="hidden md:block" />
        )
      )
    }
  </Description>

  <p class="feature-description-text text-dark/75 max-w-2xl text-base md:text-lg">
    {features.description}
  </p>

  <div class="mt-10 grid gap-10 lg:grid-cols-[0.72fr_1.28fr] lg:gap-16">
    <aside class="feature-card relative max-w-sm" data-motion-item>
      <img
        src="/treatments/treatment-hands.png"
        alt=""
        aria-hidden="true"
        class="treatment-sprite pointer-events-none mb-5 w-28 opacity-80"
        loading="lazy"
        decoding="async"
      />
      <p class="text-dark/45 text-xs uppercase tracking-[0.28em]">A calm first step</p>
      <p class="mt-3 font-serif text-2xl leading-tight">
        You do not need to know the treatment name. Start with where it hurts and what has changed.
      </p>
    </aside>

    <div class="divide-dark/10 divide-y">
      {
        Object.entries(features.featureTabs).map(([key, tab], i) => (
          <article
            class="feature-card treatment-row group relative grid gap-4 overflow-hidden py-6 sm:grid-cols-[0.42fr_1fr] sm:py-7"
            data-index={i}
            data-motion-item
          >
            <div>
              <p class="text-xs uppercase tracking-[0.2em] text-coral">{audienceTags[key] ?? ''}</p>
              <h3 class="mt-2 font-serif text-3xl font-medium">{tab.title}</h3>
            </div>
            <div class="treatment-copy">
              <img
                src={treatmentSprites[key]}
                alt=""
                aria-hidden="true"
                class="treatment-row-sprite pointer-events-none float-right mb-2 ml-4 w-20 opacity-55 transition duration-500 group-hover:opacity-80 sm:w-[4.5rem]"
                loading="lazy"
                decoding="async"
              />
              <p class="text-dark/75 text-base leading-relaxed">{tab.description}</p>
              <p class="text-dark/55 mt-3 text-sm">
                Sessions are adjusted for pressure tolerance, age, mobility, and medical history.
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { animate, cubicBezier, stagger } from 'animejs'

  animate('#services .title-line', {
    opacity: [0, 1],
    translateY: [10, 0],
    delay: stagger(120),
    duration: 500,
    ease: cubicBezier(0.25, 0.1, 0.25, 1),
  })

  animate('#services .feature-description-text', {
    opacity: [0, 1],
    translateY: [10, 0],
    delay: 400,
    duration: 500,
  })

  animate('#services .feature-card', {
    opacity: [0, 1],
    translateY: [20, 0],
    delay: stagger(120, { start: 500 }),
    duration: 600,
    ease: cubicBezier(0.25, 0.1, 0.25, 1),
  })
</script>

<style>
  .treatment-sprite {
    animation: treatment-float 8s ease-in-out infinite;
  }

  .treatment-sprite--breath {
    animation-duration: 10s;
  }

  .treatment-sprite--spine {
    animation-delay: -2s;
  }

  .treatment-row {
    transition:
      transform 500ms ease,
      background-color 500ms ease;
  }

  .treatment-row::before {
    content: '';
    position: absolute;
    inset-block: 1.25rem;
    left: 0;
    width: 2px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--zen-coral) 48%, transparent);
    opacity: 0;
    transform: scaleY(0.55);
    transition:
      opacity 400ms ease,
      transform 400ms ease;
  }

  .treatment-row:hover {
    transform: translateX(4px);
    background: color-mix(in srgb, var(--zen-cream) 28%, transparent);
  }

  .treatment-row:hover::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .treatment-row-sprite {
    transform: translateY(2px) rotate(-2deg);
  }

  .treatment-copy::after {
    content: '';
    display: block;
    clear: both;
  }

  .treatment-row:hover .treatment-row-sprite {
    transform: translateY(-2px) rotate(1deg);
  }

  @keyframes treatment-float {
    0%,
    100% {
      transform: translate3d(0, 0, 0) rotate(-1deg);
    }

    50% {
      transform: translate3d(0, -8px, 0) rotate(1deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .treatment-sprite,
    .treatment-row,
    .treatment-row::before,
    .treatment-row-sprite {
      animation: none;
      transition: none;
    }

    .treatment-row:hover {
      transform: none;
    }
  }
</style>
