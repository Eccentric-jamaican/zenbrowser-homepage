---
import { getLocale, getUI } from '~/utils/i18n'

const locale = getLocale(Astro)

const {
  routes: {
    index: { community },
  },
} = getUI(locale)

const values = [
  {
    label: 'Fact-finding',
    class: 'community-pill--compassion',
    description:
      'We start with the story: where pain shows up, what aggravates it, and what daily movements feel harder. This gives the session a clear, useful starting point.',
  },
  {
    label: 'Evaluation',
    class: 'community-pill--care',
    description:
      'Garfield checks posture, mobility, pressure tolerance, and areas that may be referring pain. The goal is to understand the body before asking it to change.',
  },
  {
    label: 'Program',
    class: 'community-pill--connection',
    description:
      'Your care plan is matched to age, sensitivity, medication, and mobility. It may combine release work, assisted movement, pacing, and simple between-visit guidance.',
  },
  {
    label: 'Treatment',
    class: 'community-pill--empowerment',
    description:
      'Hands-on work stays responsive, never rushed, and adjusts as your body responds. You leave knowing what changed and what to watch next.',
  },
]
---

<section
  id="community"
  data-motion-section
  class="community-approach relative flex w-full flex-col gap-12 overflow-hidden py-12 text-center sm:py-16 lg:py-28"
>
  <div
    class="relative mx-auto min-h-[22rem] w-full max-w-5xl px-4 sm:min-h-[24rem] lg:min-h-[28rem]"
  >
    <img
      src="/relaxed-client-cutout.png"
      alt=""
      aria-hidden="true"
      class="community-person pointer-events-none absolute left-1/2 top-0 h-24 w-24 -translate-x-1/2 object-contain object-bottom sm:h-28 sm:w-28"
      loading="lazy"
      decoding="async"
    />

    {
      values.map(value => (
        <span
          class:list={[
            'community-pill absolute rounded-xl border border-white/30 px-5 py-2 text-sm font-semibold text-paper',
            value.class,
          ]}
          data-motion-item
        >
          {value.label}
        </span>
      ))
    }

    <div class="relative z-10 mx-auto flex max-w-3xl flex-col items-center pt-28 sm:pt-32 lg:pt-36">
      <p class="text-xs uppercase tracking-[0.3em] text-coral">What to expect</p>
      <h2
        class="mt-5 max-w-3xl text-balance font-serif text-4xl font-medium leading-[1.04] sm:text-5xl lg:text-6xl"
      >
        <span>{community.title[0]}</span>
        <span>{community.title[1]}</span>
        <span>{community.title[3]}</span>
      </h2>
      <p class="text-dark/65 mt-5 max-w-2xl text-base leading-relaxed">
        {community.description}
      </p>
    </div>
  </div>

  <div
    class="community__flow mx-auto grid w-full max-w-5xl gap-7 text-left sm:grid-cols-2 lg:grid-cols-4"
  >
    {
      values.map((value, index) => (
        <div class="community__button flex flex-col gap-3" data-motion-item>
          <p class="text-xs uppercase tracking-[0.28em] text-coral">
            {String(index + 1).padStart(2, '0')}
          </p>
          <h3 class="font-serif text-2xl font-medium">{value.label}</h3>
          <p class="text-dark/70 text-sm leading-relaxed">{value.description}</p>
        </div>
      ))
    }
  </div>
</section>

<style>
  .community-person {
    filter: drop-shadow(0 16px 22px color-mix(in srgb, var(--zen-dark) 12%, transparent));
  }

  .community-pill {
    overflow: hidden;
    z-index: 20;
    transform: rotate(var(--pill-rotation, 0deg)) scale(var(--pill-scale, 1));
    animation: community-float 8s ease-in-out infinite;
    background-image:
      linear-gradient(145deg, rgb(255 255 255 / 0.16), transparent 42%),
      linear-gradient(180deg, rgb(255 255 255 / 0.1), rgb(0 0 0 / 0.08));
    box-shadow:
      0 0 0 5px rgb(255 255 255 / 0.1),
      0 12px 18px color-mix(in srgb, var(--zen-dark) 16%, transparent),
      0 2px 4px color-mix(in srgb, var(--zen-dark) 12%, transparent),
      inset 0 1px 0 rgb(255 255 255 / 0.32),
      inset 0 -2px 4px rgb(0 0 0 / 0.1);
    text-shadow: 0 1px 0 rgb(255 255 255 / 0.12);
  }

  :global(html[data-theme='dark']) .community-pill {
    box-shadow:
      0 0 0 1px rgb(255 255 255 / 0.12),
      0 8px 14px rgb(0 0 0 / 0.16),
      inset 0 1px 0 rgb(255 255 255 / 0.18),
      inset 0 -2px 4px rgb(0 0 0 / 0.16);
  }

  .community-pill--compassion {
    --pill-rotation: 8deg;
    left: 6%;
    top: 2.5rem;
    background-color: #91644e;
  }

  .community-pill--care {
    --pill-rotation: -10deg;
    left: 4%;
    top: 11.5rem;
    background-color: #6f9ed7;
    animation-delay: -1.5s;
  }

  .community-pill--connection {
    --pill-rotation: 4deg;
    right: 7%;
    top: 3.5rem;
    background-color: #7d8c55;
    animation-delay: -2.8s;
  }

  .community-pill--empowerment {
    --pill-rotation: 8deg;
    --pill-scale: 1.04;
    right: 4%;
    top: 12.5rem;
    background-color: #e57967;
    animation-delay: -4s;
  }

  @keyframes community-float {
    0%,
    100% {
      translate: 0 0;
    }

    50% {
      translate: 0 -8px;
    }
  }

  @media (max-width: 640px) {
    .community-pill {
      padding: 0.45rem 0.85rem;
      font-size: 0.75rem;
    }

    .community-pill--compassion {
      left: 0.25rem;
      top: 2.25rem;
    }

    .community-pill--care {
      left: 0.25rem;
      top: 13rem;
    }

    .community-pill--connection {
      right: 0.25rem;
      top: 3.5rem;
    }

    .community-pill--empowerment {
      --pill-scale: 1.06;
      right: 0.25rem;
      top: 14rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .community-pill {
      animation: none;
    }
  }
</style>
