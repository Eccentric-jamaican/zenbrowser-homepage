---
import Layout from '~/layouts/Layout.astro'
import { getLocale, getUI } from '~/utils/i18n'
export { getStaticPaths } from '~/utils/i18n'

const locale = getLocale(Astro)
const { layout } = getUI(locale)
---

<Layout title={layout.donate.title} description={layout.donate.description}>
  <main class="container flex min-h-[70vh] items-center justify-center py-24 text-center">
    <div class="mx-auto max-w-2xl">
      <p class="text-xs uppercase tracking-[0.3em] text-coral">Gift cards</p>
      <h1 class="mt-4 font-serif text-5xl font-medium leading-tight sm:text-7xl">Coming soon</h1>
      <p class="text-dark/70 mx-auto mt-5 max-w-xl text-base leading-relaxed sm:text-lg">
        Gift cards are not available just yet. For now, book a session directly and we will help
        arrange care for the person you have in mind.
      </p>
    </div>
  </main>
</Layout>
